@email = sebastian.lisboalisboa@gmail.com
@password = YOUR_PASSWORD

### PASO 1: Autenticar Usuario (Ejecuta primero)
# @name login
POST {{supabase_url}}/auth/v1/token?grant_type=password
apikey: {{anon_key}}
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### PASO 2: Probar Endpoint de IA (Ejecuta después del login)
# Nota: Reemplaza YOUR_ACCESS_TOKEN con el access_token del paso anterior
@access_token = YOUR_ACCESS_TOKEN

POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "200g de salmón a la plancha con brócoli al vapor"
}

###############################################
# EJEMPLOS DE PRUEBAS
###############################################

### Ejemplo 1: Comida Simple
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "dos huevos revueltos"
}

### Ejemplo 2: Comida con Peso
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "150g de pechuga de pollo a la plancha"
}

### Ejemplo 3: Comida Compuesta
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "Bowl de quinoa con pollo, aguacate, tomate cherry y aderezo de tahini"
}

### Ejemplo 4: Batido/Smoothie
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "Batido con 30g de proteína whey, una banana, 200ml de leche de almendras y una cucharada de mantequilla de maní"
}

### Ejemplo 5: Comida Detallada
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "150g de salmón a la plancha, 100g de arroz integral, 80g de brócoli al vapor y medio aguacate"
}

### Ejemplo 6: Atún (Alta Proteína)
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "200g de atún enlatado en agua"
}

### Ejemplo 7: Desayuno
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "3 huevos revueltos con queso, aguacate y dos tortillas de maíz"
}

### Ejemplo 8: Snack
POST {{supabase_url}}/functions/v1/process-food-ai
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "message": "un puñado de almendras, unos 30g"
}

###############################################
# VERIFICAR DATOS
###############################################

### Ver perfil del usuario
GET {{supabase_url}}/rest/v1/profiles?id=eq.c86e3794-3f12-4e3f-8147-3365f4b9ff41
apikey: {{anon_key}}
Authorization: Bearer {{access_token}}

### Ver últimos alimentos registrados
GET {{supabase_url}}/rest/v1/food_logs?user_id=eq.c86e3794-3f12-4e3f-8147-3365f4b9ff41&order=created_at.desc&limit=10&select=*
apikey: {{anon_key}}
Authorization: Bearer {{access_token}}

### Ver alimento específico con matriz nutricional completa
GET {{supabase_url}}/rest/v1/food_logs?user_id=eq.c86e3794-3f12-4e3f-8147-3365f4b9ff41&order=created_at.desc&limit=1&select=food_name,quantity_g,calories,protein_g,nutritional_matrix
apikey: {{anon_key}}
Authorization: Bearer {{access_token}}
